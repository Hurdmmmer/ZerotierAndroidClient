<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/space_md"
    android:layout_marginTop="@dimen/space_md"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="0dp"
    app:contentPadding="@dimen/card_padding"
    app:strokeColor="?attr/tableRowGrey"
    app:strokeWidth="@dimen/card_stroke">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/moon_world_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:text="8056c2e21c"
            android:textColor="?attr/greyText"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/moon_seed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:text="-"
            android:textColor="?attr/greyText"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/moon_config"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:text="@string/wait_to_fetch"
            android:textColor="?attr/greyText"
            android:textSize="13sp" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
